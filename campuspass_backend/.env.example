# Django
DJANGO_SECRET_KEY=campuspass-dev-secret-key-change-in-production
DEBUG=True
ALLOWED_HOSTS=*

# Database
DB_NAME=campuspass
DB_USER=campuspass_user
DB_PASSWORD=campuspass_pass
DB_HOST=localhost
DB_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379/0

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Email
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@campuspass.edu

# QR Code
QR_CODE_EXPIRY_HOURS=24
QR_CODE_MAX_VERIFICATIONS=2

# Outpass Settings
OUTPASS_MAX_ACTIVE=3
OUTPASS_DEFAULT_DURATION_HOURS=4

# Notification
NOTIFICATION_METHOD=database

# Sentry (optional)
SENTRY_DSN=

# FCM (optional)
FCM_SERVER_KEY=

# Twilio (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
